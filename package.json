{
  "name": "retro-board",
  "version": "1.0.0",
  "description": "Self-hosted real-time retrospective board",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npx concurrently --names \"server,client\" --prefix-colors \"cyan,magenta\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "start": "cd server && npm start",
    "build:client": "cd client && npm run build",
    "gen-api": "npm run gen-api --prefix server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
